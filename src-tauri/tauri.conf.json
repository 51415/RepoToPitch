{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RepoToPitch",
  "version": "1.1.1",
  "identifier": "com.repotopitch.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4029",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RepoToPitch",
        "width": 1280,
        "height": 1300,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": null,
    "fs": null,
    "http": null,
    "log": null
  }
}
