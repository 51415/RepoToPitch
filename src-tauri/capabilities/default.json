{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-ask",
    "dialog:allow-message",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-applocaldata-read-recursive",
    "fs:allow-applocaldata-write-recursive",
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "**", "recursive": true }]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**", "recursive": true }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**", "recursive": true }]
    },
    "core:path:default",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://repotopitch.lemonsqueezy.com/**" }
      ]
    },
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "http://localhost:11434/**"
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "powershell",
          "cmd": "powershell",
          "args": [
            "-Command",
            {
              "validator": "[\\s\\S]*"
            }
          ]

        },
        {
          "name": "soffice-6",
          "cmd": "soffice",
          "args": [
            { "validator": ".+" },
            { "validator": ".+" },
            { "validator": ".+" },
            { "validator": ".+" },
            { "validator": ".+" },
            { "validator": ".+" }
          ]
        },
        {
          "name": "soffice-1",
          "cmd": "soffice",
          "args": [
            { "validator": ".+" }
          ]
        }
      ]
    }
  ]
}



